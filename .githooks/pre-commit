#!/usr/bin/env bash
# Pre-commit hook: regenerate dev-blog/posts/posts.json from .md files
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BLOG_SCRIPT="${ROOT_DIR}/dev-blog/scripts/generate-posts-json.mjs"
AQI_SCRIPT="${ROOT_DIR}/scripts/uk_aq_inject_project_ref.mjs"

if [[ ! -f "${BLOG_SCRIPT}" ]]; then
  echo "ERROR: dev-blog generator script not found: ${BLOG_SCRIPT}" >&2
  exit 1
fi

node "${BLOG_SCRIPT}"

# Stage the regenerated file so it is included in the commit
git -C "${ROOT_DIR}" add dev-blog/posts/posts.json

if [[ -f "${AQI_SCRIPT}" ]]; then
  node "${AQI_SCRIPT}"
  git -C "${ROOT_DIR}" add hex_map.html index.html sensors_chart.html sensors_map.html
else
  echo "Skipping AQI injector: ${AQI_SCRIPT} not found" >&2
fi
